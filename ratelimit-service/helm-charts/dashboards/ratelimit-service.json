{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Rate Limit Requests",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(ratelimit_requests_total{result=\"allowed\"}[1m])",
          "legendFormat": "Allowed"
        },
        {
          "expr": "rate(ratelimit_requests_total{result=\"rejected\"}[1m])",
          "legendFormat": "Rejected"
        }
      ]
    },
    {
      "title": "Active Limits",
      "type": "stat",
      "targets": [
        {
          "expr": "ratelimit_active_limits_total",
          "legendFormat": "Active Limits"
        }
      ]
    },
    {
      "title": "Violating Users",
      "type": "stat",
      "targets": [
        {
          "expr": "ratelimit_violating_users_total",
          "legendFormat": "Violating Users"
        }
      ]
    },
    {
      "title": "Redis Operations",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(ratelimit_redis_operations_total[1m])",
          "legendFormat": "Redis Ops/sec"
        }
      ]
    }
  ]
}